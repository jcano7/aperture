import sys
import os
import cv2
from PyQt6.QtWidgets import (
    QApplication, 
    QMainWindow, 
    QWidget, 
    QLabel, 
    QGridLayout, 
    QVBoxLayout, 
    QPushButton
)
from PyQt6.QtCore import QThread, pyqtSignal, Qt
from PyQt6.QtGui import QImage, QPixmap

class VideoThread(QThread):
    #signal to send frame to gui thread
    change_pixmap_signal = pyqtSignal(QImage)

    def __init__(self, rtsp_url):
        super().__init__()
        self.rtsp_url = rtsp_url
        self._run_flag = True

    def run(self):
        #setting a timeout for the stream in microseconds
        os.environ["OPENCV_FFMPEG_CAPTURE_OPTIONS"] = "timeout;5000000"
        #CAP_FFMPEG much faster for RTSP streams
        cap = cv2.VideoCapture(self.rtsp_url, cv2.CAP_FFMPEG)

        while self._run_flag:
            ret, cv_img = cap.read()
            if ret:
                #conversion of BGR(OpenCV) to RGB(Qt)
                h, w, ch = cv_img.shape
                bytes_per_line = ch * w
                qt_img = QImage(cv_img.data, w, h, bytes_per_line, QImage.Format.Format_RGB888).rgbSwapped()
                #scale for performance 4:3 aspect ratio kept
                p = qt_img.scaled(640, 480, Qt.AspectRatioMode.KeepAspectRatio).copy() #.copy() ensures QImage owns its own memory.
                self.change_pixmap_signal.emit(p)
            else:
                #if stream breaks, dont spin the CPU
                self.msleep(10)

        cap.release()
        print("Thread finished cleanly")##debug print statement 

    def stop(self):
        self._run_flag = False
        self.wait()

class SecurityDashboard(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Aperture Pre Alpha Build")
        self.resize(1200, 800)

        # Main Layout
        self.central_widget = QWidget()
        self.setCentralWidget(self.central_widget)
        self.main_layout = QGridLayout(self.central_widget)

        # Camera Display Labels
        self.cam_labels = [QLabel("Attempting to Establish Connection...") for _ in range(3)]
        for i, label in enumerate(self.cam_labels):
            label.setStyleSheet("background-color: black; border: 2px solid #233;")
            label.setAlignment(Qt.AlignmentFlag.AlignCenter)
            # Place in grid (Row 0, Col i)
            self.main_layout.addWidget(label, 0, i)

        # Placeholder for future sensors (Row 1)
        self.sensor_panel = QLabel("Sensor Status: Offline (Ready for future integration)")
        self.sensor_panel.setStyleSheet("color: gray; font-size: 14px; padding: 10px;")
        self.main_layout.addWidget(self.sensor_panel, 1, 0, 1, 3)

        # RTSP URLs (streamaddress placeholders)
        urls = [
            "rtsp://username:password@192.168.1.101:554/stream1",
            "rtsp://username:password@192.168.1.102:554/stream1",
            "rtsp://username:password@192.168.1.103:554/stream1"     
        ]

        # Start Threads
        self.threads = []
        for i, url in enumerate(urls):
            thread = VideoThread(url)
            # Connect the video signal to a specific lambda to update correct label
            thread.change_pixmap_signal.connect(lambda img, l=self.cam_labels[i]: self.update_image(img, l))
            thread.start()
            self.threads.append(thread)
        
    def update_image(self, qt_img, label):
        label.setPixmap(QPixmap.fromImage(qt_img))

    def closeEvent(self, event): #Changed to fix hanging upon application exit
        #1 signal the thread to stop the loop
        self.thread.running = False

        #2 wait for the thread to finish cleanly
        self.thread.quit()
        self.thread.wait()

        #3 accept the event to close the window
        event.accept()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = SecurityDashboard()
    window.show()
    sys.exit(app.exec())

